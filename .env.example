# --- Required: Google OAuth client (from GCP Console) ---
# Create at https://console.cloud.google.com/apis/credentials
# OAuth 2.0 Client ID, type: Web application
# Authorized redirect URI: ${BASE_URL}/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Required: this server's public base URL ---
# Used to compute the Google redirect URI registered above and the
# OAuth issuer advertised in /.well-known metadata.
# Local dev: http://localhost:8433
# Production: https://google-mcp.example.com
BASE_URL=http://localhost:8433

# --- Required: HS256 secret for signing MCP JWTs (issued to MCP clients) ---
# Generate with: openssl rand -hex 64
JWT_SECRET=

# --- Required: 32 bytes of randomness, base64url-encoded ---
# Encrypts Google refresh tokens at rest in the SQLite store.
# Generate with: openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
STORAGE_ENCRYPTION_KEY=

# --- Optional ---
# DATABASE_URL=./google-mcp.db
# MCP_HOST=0.0.0.0
# MCP_PORT=8433
# CORS_ALLOW_LOCALHOST=true
# RUST_LOG=google_mcp=info,rmcp=warn,reqwest=warn

# --- Optional: filesystem file exchange (local-first deployments) ---
# Absolute path to a directory the file tools may read attachments from and
# write downloads to. docker-compose bind-mounts it into the container at the
# SAME path, so your MCP client and this server name files identically. This
# lets you attach/download files by PATH instead of shovelling base64 through
# the model's context — far cheaper and more reliable.
#   - Attach a local file:   gmail_send attachments=[{ path: "<FILE_ROOT>/report.pdf" }]
#   - Save an attachment:    gmail_download_attachment dest_path="<FILE_ROOT>/in.pdf"
#   - Move Gmail <-> Drive:  attachments=[{ drive_file_id: "..." }] / to_drive_folder_id
# The container runs as uid 65532; make the directory writable by it, e.g.:
#   mkdir -p ~/.google-mcp/exchange && chmod 0777 ~/.google-mcp/exchange
# Leave unset to disable path-based exchange (base64-only fallback).
# FILE_ROOT=/home/youruser/.google-mcp/exchange

# --- Optional: scope which Google Workspace surfaces this server exposes ---
# Comma-separated list (case-insensitive). Unset or empty = all five.
# Each entry shrinks (a) the MCP tool surface — fewer context tokens
# per agent session — and (b) the OAuth scope set requested from Google
# at consent time, so users only grant the access the operator intends.
# Valid values: gmail, sheets, drive, docs, calendar
# Example (Gmail-only deployment):
# ENABLED_DOMAINS=gmail
